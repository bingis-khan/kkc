use Iter
	to

fn pow (base, p):
	0 to (p - 1) Iter.reduce(1, fn(item, x): x * base)

fn mod(l, d)
	r = l / d
	# There should be an assert that r >= 0...
	m = l - r * d

	if m < 0
		return d + m
	else
		return m

fn min(l, r)
	if l < r
		return l
	else
		return r

fn max(l, r)
	if l > r
		return l
	else
		return r

fn sqrt(f F64):
	Cnile.sqrt(f)  # geeeeeeg

fn floor(f F64): @f64-i64-floor(f)
