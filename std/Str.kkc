###### Functions ######

fn nullchar() -> Char: Mem.zeroed()  # HACK!!
fn nullchar-u8() -> U8: Mem.zeroed()  # HACK!!
# fn eq(l, r): l chars() zip(r chars()) all(fn Tuple2(lc, rc): lc == rc)  # this is incorrect, because zip() trims!
fn eq(l, r)
	l =& l chars()
	r =& r chars()

	while True
		mlc = l next()
		mrc = r next()

		case (mlc, mrc)
			(None, None)
				return True

			(Just(lc), Just(rc))
				if lc /= rc
					return False

			_
				return False


fn streq(l, r): eq(l, r)
fn char-i32(c Char) -> I32:
	Mem.cast-on-zeroed(c)
fn char-u8(c Char) -> U8:
	Mem.cast(c)
fn u8-char(c U8) -> Char:
	Mem.cast(c)
fn i32-char(i I32) -> Char:
	Mem.cast(i)


fn const-str-len (s ConstStr):
	s chars() count()  # SIKE. Im using iterators.

###### Other Instances #####

inst Eq ConstStr
	eq (l, r): Cnile.strcmp(l, r) == 0

inst Ord Char
	cmp (l, r): cmp(char-i32(l), char-i32(r))
