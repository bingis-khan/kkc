# seed for stateful random number gen.
Cnile.srand(Cnile.time(Mem.null-c-ptr()) Mem.cast())

fn next-i32() -> I32: Cnile.rand()
fn next-u32() -> U32: Cnile.rand() Mem.cast()


# in the future, make a typeclass for random number gen.
# and then there should be a function like `next()`,
# which automatically generates!
