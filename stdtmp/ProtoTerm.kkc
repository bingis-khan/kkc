use Str
	Str
use Iter
	for-each
	drop
	head
	
fn print-char (Char(u32))
	# buf =& Str.char-to-zt-buf(c) fst()
	# Cnile.printf1('%s', Mem.cast(&buf))
	# TEMP
	c = u32 Mem.u32-u8() Mem.cast() as AsciiChar
	Cnile.printf1('%c', c)

fn print-str(s Str)
	s Str.chars() Iter.for-each(print-char)

fn print-as-list(it)
	print-str('[')
	case it head()
		None
			pass
		Just(x)
			print-str(x)

	it drop(1) for-each(fn x: ', \(x)' print-str())
	print-str(']')
