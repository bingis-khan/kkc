#$ Generalize functions over typeclass constraints with multiple instances, one defined after general function.
# 69
# 192

class MyAsInt
	to-int (self _) -> I32

inst MyAsInt I32
	to-int (self I32) -> I32
		return self

fn turn-to-int-and-add-69 (x)
	return to-int(x) + 69

inst MyAsInt Bool
	to-int (self Bool) -> I32
		if self
			return 1
		else
			return 0


println(turn-to-int-and-add-69(False))
println(turn-to-int-and-add-69(123))
