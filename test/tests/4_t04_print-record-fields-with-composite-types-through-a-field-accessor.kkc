#$ Print record fields with composite types (through field accessors.)
# ()
# 1337
# True

MyRecord
	nice Unit
	other-nice Maybe I32
	other-other-nice Either I32 (Maybe Bool)

rec = MyRecord { nice: Unit, other-nice: Just(1337), other-other-nice: Right(Just(True)) }

fn pmaybe (Just(x) Maybe a) -> Unit <= Str a
	println(x)

fn peithermaybe (Right(Just(x)) Either e (Maybe a)) -> Unit <= Str a
	println(x)

println(rec.nice)
pmaybe(rec.other-nice)
peithermaybe(rec.other-other-nice)
