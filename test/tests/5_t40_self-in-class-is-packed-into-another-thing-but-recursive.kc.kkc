#$ Self in class is packed into another thing but recursive.
# 421
# 1340

NotPtr a
	NotPtr a

class Iter
	next (self NotPtr _) -> I32

inst Iter I32
	next (NotPtr(x)) -> I32
		return x

inst Iter NotPtr
	next (NotPtr(x)) -> I32
		return next(x) + 1

x = NotPtr(NotPtr(420))
println(next(x))
println(next(NotPtr(NotPtr(NotPtr(NotPtr(1337))))))
